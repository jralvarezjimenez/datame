rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isVeterinarianOrStaff() {
      return isAuthenticated() && (getUserData().role == 'veterinarian' || getUserData().role == 'staff');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Assumed Data Model
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'veterinarian', 'staff', 'owner')
    //   - clinicId: string (optional)

    match /users/{userId} {
      allow read: if isOwner(userId) || isVeterinarianOrStaff();
      allow create: if isAuthenticated() && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role; // Cannot change own role
    }

    // Collection: patients
    // Document ID: {patientId}
    // Fields:
    //   - name: string (required, max 50 chars)
    //   - species: string (required, max 20 chars)
    //   - breed: string (optional, max 30 chars)
    //   - age: number (optional, positive)
    //   - ownerId: string (required)

    match /patients/{patientId} {
      allow read: if isVeterinarianOrStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
      allow create: if isVeterinarianOrStaff() || (isAuthenticated() && request.resource.data.ownerId == request.auth.uid);
      allow update: if isVeterinarianOrStaff() || (isAuthenticated() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if isVeterinarianOrStaff();
    }

    // Clinical records: vet/staff have full access, owners can read their pet's records
    match /consultations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isVeterinarianOrStaff();
    }

    match /vaccinations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isVeterinarianOrStaff();
    }

    match /prescriptions/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isVeterinarianOrStaff();
    }

    match /appointments/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isVeterinarianOrStaff();
    }
  }
}
